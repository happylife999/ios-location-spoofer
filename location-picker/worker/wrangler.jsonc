  "kv_namespaces": [
    {
      "binding": "LOC_KV",
      "id": "aab71263e60541f1a68e3e5d13b24fbb",
      "preview_id": "5a3bc7d441bb4cacaad7be32cf7fc4b7"
    }
  ]
}
